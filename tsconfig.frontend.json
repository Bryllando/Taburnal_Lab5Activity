{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "ignoreDeprecations": "6.0",
        "lib": [
            "ES2020",
            "DOM"
        ],
        "outDir": "./public",
        "rootDir": "./src/frontend",
        "strict": false,
        "skipLibCheck": true
    },
    "include": [
        "src/frontend/**/*"
    ],
    "exclude": [
        "node_modules"
    ]
}